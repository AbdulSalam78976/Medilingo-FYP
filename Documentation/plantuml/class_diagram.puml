@startuml class_diagram
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #002B5B
  ArrowColor #0066B3
  FontColor #002B5B
  HeaderBackgroundColor #002B5B
  HeaderFontColor white
}
skinparam backgroundColor white

class UserDoc {
  + id : str (UUID4)
  + username : str
  + email : str
  + hashed_password : str
  + role : str
  + created_at : datetime
  --
  + to_mongo() : dict
  + {static} from_mongo(d) : UserDoc
}

class SessionDoc {
  + id : str (UUID4)
  + user_id : str
  + title : str
  + created_at : datetime
  + updated_at : datetime
  + messages : List[MessageDoc]
  --
  + to_mongo() : dict
  + {static} from_mongo(d) : SessionDoc
}

class MessageDoc {
  + id : str (UUID4)
  + role : str
  + content : str
  + language : str
  + timestamp : datetime
  --
  + to_mongo() : dict
  + {static} from_mongo(d) : MessageDoc
}

class RAGQueryEngine {
  - embedding_gen : EmbeddingGenerator
  - vector_store : ChromaDBVectorStore
  - groq_client : Groq
  - model : str
  --
  + process_query(query: str) : str
  + strip_prefix(query: str) : str
  + build_prompt(context, query) : list
}

class EmbeddingGenerator {
  - model : SentenceTransformer
  - model_name : str
  --
  + encode(text: str) : ndarray
  + encode_batch(texts: list) : ndarray
}

class ChromaDBVectorStore {
  - client : chromadb.Client
  - collection : Collection
  - collection_name : str
  --
  + query(vector, k: int) : List[str]
  + upsert(docs, vectors, metadata) : void
  + count() : int
}

class RAGIngestionPipeline {
  - embedding_gen : EmbeddingGenerator
  - vector_store : ChromaDBVectorStore
  - chunk_size : int
  - overlap : int
  --
  + run(datasets_dir: str) : dict
  + load_pdfs(path: str) : List[str]
  + chunk_text(text: str) : List[str]
}

UserDoc "1" --> "0..*" SessionDoc : owns
SessionDoc "1" *-- "0..*" MessageDoc : contains

RAGQueryEngine --> EmbeddingGenerator : uses
RAGQueryEngine --> ChromaDBVectorStore : queries
RAGIngestionPipeline --> EmbeddingGenerator : uses
RAGIngestionPipeline --> ChromaDBVectorStore : writes
@enduml
