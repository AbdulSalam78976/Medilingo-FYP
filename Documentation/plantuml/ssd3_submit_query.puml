@startuml ssd3_submit_query
skinparam sequence {
  ArrowColor #0066B3
  LifeLineBorderColor #002B5B
  LifeLineBackgroundColor #EEF5FF
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #002B5B
  ParticipantFontColor #002B5B
  ActorBorderColor #002B5B
  BackgroundColor white
}
skinparam backgroundColor white

title SSD-3: Submit Medical Query

actor User
participant "Frontend\n(React SPA)" as FE
participant "FastAPI\nBackend" as API
participant "RAG Engine" as RAG
database "ChromaDB" as VDB
participant "Groq API\n(LLaMA 3.3-70b)" as LLM
database "MongoDB" as DB

User -> FE : type query + select language
FE -> FE : prepend language prefix\n"Respond in [L]: [query]"
FE -> API : POST /query\n{ query: prefixed_text, session_id }

API -> RAG : process(query)
RAG -> RAG : strip language prefix\nclean_query = medical text only
RAG -> RAG : embed(clean_query)\nall-MiniLM-L6-v2 → 384-dim vector
RAG -> VDB : cosine search(vector, k=5)
VDB --> RAG : top-5 relevant passages

RAG -> LLM : chat.completions(\n  system: lang_instruction + context,\n  user: original_query\n)
LLM --> RAG : response text in language L

RAG --> API : answer

API -> DB : save MessageDoc\n(user query + assistant response)
DB --> API : ack

API --> FE : 200 OK { answer }
FE --> User : render response in chat
@enduml
