@startuml domain_model
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #002B5B
  ArrowColor #0066B3
  FontColor #002B5B
  HeaderBackgroundColor #002B5B
  HeaderFontColor white
}
skinparam backgroundColor white

class User {
  + id : String (UUID4)
  + name : String
  + email : String
  + password_hash : String
  + role : Enum {user, admin}
  + is_active : Boolean
  + created_at : DateTime
}

class Session {
  + id : String (UUID4)
  + user_id : String
  + title : String
  + created_at : DateTime
  + updated_at : DateTime
}

class Message {
  + id : String (UUID4)
  + session_id : String
  + role : Enum {user, assistant}
  + content : String
  + language : String
  + timestamp : DateTime
}

User "1" --o "0..*" Session : owns >
Session "1" --o "0..*" Message : contains >

note bottom of User
  Stored in MongoDB
  collection: users
end note

note bottom of Session
  Stored in MongoDB
  collection: sessions
end note

note bottom of Message
  Stored in MongoDB
  embedded in session
end note
@enduml
