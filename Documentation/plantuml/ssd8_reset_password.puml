@startuml ssd8_reset_password
skinparam sequence {
  ArrowColor #0066B3
  LifeLineBorderColor #002B5B
  LifeLineBackgroundColor #EEF5FF
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #002B5B
  ParticipantFontColor #002B5B
  ActorBorderColor #002B5B
  BackgroundColor white
}
skinparam backgroundColor white

title SSD-8: Reset Password via Email OTP

actor User
participant "Frontend\n(React SPA)" as FE
participant "FastAPI\nBackend" as API
participant "Email\nService" as EMAIL
database "MongoDB" as DB

== Step 1: Request OTP ==
User -> FE : navigate to /forgot-password\nenter registered email
FE -> API : POST /auth/forgot-password\n{ email }
API -> DB : findUser(email)
alt Account exists
  DB --> API : UserDoc
  API -> API : generate time-limited OTP
  API -> DB : storeOTP(user_id, otp, expiry)
  API -> EMAIL : sendOTPEmail(email, otp)
  EMAIL --> User : OTP arrives in inbox
  API --> FE : 200 OK
  FE --> User : "Check your email for the OTP"
else No account found
  DB --> API : null
  API --> FE : 404 Not Found
  FE --> User : show error
end

== Step 2: Submit OTP + New Password ==
User -> FE : enter OTP + new password
FE -> API : POST /auth/reset-password\n{ email, otp, new_password }
API -> DB : findOTP(email, otp)
alt OTP valid and not expired
  DB --> API : OTP record
  API -> API : hash new_password (bcrypt)
  API -> DB : updateUser(password_hash)
  API -> DB : deleteOTP(user_id)
  API --> FE : 200 OK
  FE --> User : redirect to /login
else OTP expired or wrong
  API --> FE : 400 Bad Request
  FE --> User : "OTP invalid or expired"
end
@enduml
