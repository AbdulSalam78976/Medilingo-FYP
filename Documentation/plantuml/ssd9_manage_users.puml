@startuml ssd9_manage_users
skinparam sequence {
  ArrowColor #0066B3
  LifeLineBorderColor #002B5B
  LifeLineBackgroundColor #EEF5FF
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #002B5B
  ParticipantFontColor #002B5B
  ActorBorderColor #002B5B
  BackgroundColor white
}
skinparam backgroundColor white

title SSD-9: Manage Users (Admin)

actor Admin
participant "Frontend\n(Admin Panel)" as FE
participant "FastAPI\nBackend" as API
database "MongoDB" as DB

Admin -> FE : navigate to /admin
FE -> API : GET /admin/users
API -> DB : findAllUsers()
DB --> API : users[]
API --> FE : 200 { users[] }
FE --> Admin : display paginated user list

Admin -> FE : click activate/deactivate toggle
FE -> API : PATCH /admin/users/{id}\n{ is_active: true/false }

alt Not own account
  API -> DB : updateUser(id, is_active)
  DB --> API : ack
  API --> FE : 200 OK
  FE --> Admin : update toggle in UI
else Admin deactivating own account
  API --> FE : 400 Bad Request\n"Cannot deactivate own account"
  FE --> Admin : show error
end
@enduml
